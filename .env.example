# ──────────────────────────────────────────────────────────────────────────────
# ROK Racers JA — Environment Variables Template
# Copy this file to .env and fill in the real values.
# This file is safe to commit — it contains no real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (public values — safe in browser code by Supabase design) ────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Supabase (server-side only — NEVER expose to the browser) ─────────────────
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Stripe (server-side only — NEVER expose to the browser) ──────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret_here
