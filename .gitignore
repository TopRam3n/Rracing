.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
.next/
.vercel/
out/

# ── OS files ──────────────────────────────────────────────────────────────────
